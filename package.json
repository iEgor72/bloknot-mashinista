{
  "name": "bloknot-mashinista",
  "version": "1.0.0",
  "private": true,
  "description": "Блокнот машиниста — учёт смен для локомотивных бригад",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "memory:init": "python tools/agent_memory.py init",
    "memory:preflight": "python tools/agent_memory.py preflight",
    "memory:refresh": "python tools/agent_memory.py refresh",
    "memory:log": "python tools/agent_memory.py log",
    "memory:install-hooks": "python tools/agent_memory.py install-hooks",
    "memory:sync": "python tools/agent_memory.py sync --direction push"
  }
}
